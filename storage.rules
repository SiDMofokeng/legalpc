rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(
        /databases/$(database)/documents/accounts/lpc-main/users/$(request.auth.uid)
      ).data;
    }

    function isAllowlistedAdmin() {
      return signedIn() && request.auth.token.email in ['sydney@dreamincolor.co.za'];
    }

    function isAdmin() {
      return isAllowlistedAdmin()
        || (signedIn()
          && userDoc().role == 'Admin'
          && userDoc().status == 'active');
    }

    // Only admins can upload/read knowledge files
    match /knowledgeUploads/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}