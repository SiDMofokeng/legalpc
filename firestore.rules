rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/accounts/lpc-main/users/$(request.auth.uid)).data;
    }

    // Emergency allowlist for bootstrap/admin recovery (remove once stable)
    function isAllowlistedAdmin() {
      return signedIn() && request.auth.token.email in ['sydney@dreamincolor.co.za'];
    }

    function isAdmin() {
      return isAllowlistedAdmin()
        || (signedIn()
          && userDoc().role == 'Admin'
          && userDoc().status == 'active');
    }

    function isActiveAgent() {
      return signedIn()
        && userDoc().role == 'Agent'
        && userDoc().status == 'active';
    }

    /* ---------------- Shared scope: accounts/lpc-main ---------------- */

    match /accounts/lpc-main/users/{uid} {
      allow read: if signedIn();

      // Admin can manage users
      allow create, delete: if isAdmin();

      // Admin can update any user doc
      allow update: if isAdmin();

      // Agent can only update their own profile fields
      allow update: if isActiveAgent() && request.auth.uid == uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'name', 'avatar', 'updatedAt'
        ]);
    }

    match /accounts/lpc-main/invites/{inviteId} {
      allow read, write: if isAdmin();
    }

    match /accounts/lpc-main/chatbots/{botId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /accounts/lpc-main/aiConfigs/{botId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /accounts/lpc-main/knowledgeSources/{sourceId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /accounts/lpc-main/tickets/{ticketId} {
      // Admin can read/write all tickets
      allow read, write: if isAdmin();

      // Agents can read tickets assigned to them (by uid)
      allow read: if isActiveAgent() && resource.data.assignedToUid == request.auth.uid;

      // Agents can only comment/update conversation + history on assigned tickets
      allow update: if isActiveAgent()
        && resource.data.assignedToUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'conversation', 'history', 'lastUpdate', 'updatedAt'
        ]);
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
